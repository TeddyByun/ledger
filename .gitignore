# 환경변수 (비밀번호 포함 — 커밋 금지)
.env
.env.local
.env.*.local

# 의존성
node_modules/

# 빌드 산출물
dist/
build/
.next/
out/
*.tsbuildinfo

# Turbo
.turbo/

# Prisma 생성물
**/generated/

# 로그
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store

# 실수로 src 에 방출된 빌드 산출물 방지
packages/shared/src/*.js
packages/shared/src/*.js.map

# 실제 명세서 파일(개인 금융정보) — 커밋 금지, README/구조만 유지
apps/api/test/fixtures/statements/**/*.xlsx
apps/api/test/fixtures/statements/**/*.xls
apps/api/test/fixtures/statements/**/*.csv

# 파서 개발용 임시 미리보기 스크립트
apps/api/_preview.ts
apps/api/_dump.mjs
apps/api/_merchants.mjs

# 업로드 원본 저장(개인 금융정보) — 커밋 금지
apps/api/uploads/
uploads/

# PM2 런타임 로그
.pm2-logs/
