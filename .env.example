# PostgreSQL 데이터베이스 연결 정보 (예시 — 실제 값은 .env 에 작성)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres

# 연결 문자열 (ORM/라이브러리에서 바로 사용 가능)
# ?schema=ledger — 앱 전용 스키마 지정
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=ledger

# API 서버
PORT=4000

# 적재 파이프라인 큐 (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# 업로드 원본 저장 경로 (로컬 스토리지)
UPLOAD_DIR=./uploads
