# ── 가계부 API 환경변수 (설계 반영) ─────────────────────────
# 실제 값은 .env 에 작성한다(.env 는 git 무시). 부팅 시 zod 로 검증(fail-fast).

# ── DB / 인프라 (Phase 0) ──
# 로컬 docker: docker-compose 의 postgres/redis 사용
DATABASE_URL=postgresql://ledger:ledger@localhost:5432/ledger?schema=ledger
REDIS_URL=redis://localhost:6379

# ── 서버 (Phase 0) ──
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug
WEB_ORIGIN=http://localhost:3000

# ── 인증 / JWT (Phase 1) ──
# 시크릿은 최소 32자 랜덤. 예: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── 파일 저장소 (Phase 3 → 6) ──
# STORAGE_DRIVER: local(dev/test) | google(운영)
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# ── 구글 드라이브 연동 (Phase 6) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/integrations/google/callback
# refresh token 암호화 키(32바이트). 예: openssl rand -hex 32
STORAGE_ENC_KEY=
